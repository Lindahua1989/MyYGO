# Godot engine specific ignores
.godot/
*.import

# Python cache
__pycache__/
*.pyc

# Node.js
node_modules/
package-lock.json

# OS specific
.DS_Store
Thumbs.db
desktop.ini

# Build outputs
builds/
export/

# IDE
.vscode/
.idea/

# Original BMP source files (we keep PNGs only)
assets/cards/art/*.bmp
assets/cards/mini/*.bmp
assets/ui/*.bmp

# Generated database (can be regenerated by tools)
# NOTE: We DO commit card_database.json so other developers don't need to run the pipeline

# Temp files
*.tmp
*.bak
